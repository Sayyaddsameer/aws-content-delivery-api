# =============================================================================
# AWS PRODUCTION ENVIRONMENT — copy this to .env and fill in real values
# =============================================================================

# ── PostgreSQL (AWS RDS) ──────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME
DATABASE_URL=postgresql://cdnuser:CHANGE_ME@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/cdndb

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL blank → boto3 uses real AWS S3 (not MinIO)
S3_ENDPOINT_URL=
S3_BUCKET_NAME=your-cdn-assets-bucket
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── AWS CloudFront ────────────────────────────────────────────────────────────
CDN_ENABLED=true
CDN_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXXXXXX

# ── Origin Shield ─────────────────────────────────────────────────────────────
# Set to true after you configure X-CDN-Secret as a CloudFront custom origin header
ORIGIN_SHIELD_ENABLED=true

# ── Private Access Token TTL ──────────────────────────────────────────────────
TOKEN_TTL_SECONDS=3600
