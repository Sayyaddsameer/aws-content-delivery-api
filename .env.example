# Database
DATABASE_URL=postgresql://cdnuser:cdnpass@postgres:5432/cdndb

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=cdn-assets
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# CDN (CloudFront)
CDN_ENABLED=false
CDN_SECRET=change-me-to-a-long-random-secret
CLOUDFRONT_DISTRIBUTION_ID=XXXXXXXXXXXXXXXXX

# Origin Shield
ORIGIN_SHIELD_ENABLED=false

# Access Token TTL
TOKEN_TTL_SECONDS=3600
